SERVER_HOST=213.109.202.61
SERVER_USER=root
SERVER_PORT=22

REPO_URL=https://github.com/Mikarmk/clowcodex.git
REPO_BRANCH=main

CLOWCODEX_SERVICE_USER=clowcodex
CLOWCODEX_SERVICE_GROUP=clowcodex
CLOWCODEX_BASE_DIR=/opt/clowcodex
CLOWCODEX_REPO_DIR=/opt/clowcodex/repo
CLOWCODEX_WORKDIR=/opt/clowcodex/repo
CLOWCODEX_ENV_FILE=/etc/clowcodex/clowcodex.env
CLOWCODEX_GATEWAY_PORT=18789

TELEGRAM_BOT_TOKEN=

# Default is pairing. Use allowlist only if you know your numeric Telegram user ID.
CLOWCODEX_TELEGRAM_DM_POLICY=pairing
CLOWCODEX_TELEGRAM_ALLOW_FROM_JSON=[]

# Codex runtime. OPENAI_API_KEY is optional if you copy an existing auth.json on the host.
OPENAI_API_KEY=
CLOWCODEX_CODEX_MODEL=gpt-5.3-codex
CLOWCODEX_CODEX_REASONING=high

# If set to 1, install/update will copy /root/.codex/auth.json to the service user when present.
CLOWCODEX_COPY_ROOT_CODEX_AUTH=1

